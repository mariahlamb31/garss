FROM node:22-bookworm

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY scripts ./scripts

ENV PORT=3001
ENV HOST=0.0.0.0
ENV APP_ROOT=/app
ENV RSSHUB_BASE_URL=http://rsshub:1200

EXPOSE 3001

CMD ["node", "scripts/dev-entrypoint.mjs", "node", "./node_modules/.bin/tsx", "server/index.ts"]
