{
  "name": "garss-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "backend": "tsx server/index.ts",
    "backend:watch": "tsx watch server/index.ts",
    "dev": "vite",
    "dev:docker": "vite --host 0.0.0.0 --port 25173",
    "build": "npm run typecheck && npm run build:server && vite build",
    "build:static": "npm run typecheck:app && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "sync:editreadme": "node scripts/sync-editreadme.mjs",
    "sync:garss-info": "node scripts/sync-garss-info.mjs",
    "typecheck": "npm run typecheck:app && npm run typecheck:server",
    "test:url-routing": "node --test src/lib/navigation.test.ts",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "preview": "vite preview",
    "sync:rsshub-docs": "node scripts/sync-rsshub-docs.mjs",
    "sync:sources": "npm run sync:editreadme && npm run sync:rsshub-docs",
    "test:subscription-routes": "node --test src/lib/subscription-route.test.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
